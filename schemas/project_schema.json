{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://re-dcf-core/schemas/project_schema.json",
  "title": "Urban Renewal Project (RE-DCF Core 合約)",
  "description": "RE-DCF Core Engine 對外唯一資料合約。Dashboard / Simulator / AI Copilot 一律消費此格式，不得自行重算公式。內部 domain 用中文，對外 key 用英文。",
  "type": "object",
  "required": ["schema_version", "project", "land", "building", "result"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "合約版本，破壞性變更時遞增"
    },
    "project": {
      "type": "object",
      "required": ["name", "renewal_type"],
      "properties": {
        "name": { "type": "string", "description": "案件名稱" },
        "renewal_type": {
          "type": "string",
          "enum": ["urban_renewal", "danger_building"],
          "description": "都更 urban_renewal / 危老 danger_building"
        }
      }
    },
    "land": {
      "type": "object",
      "required": ["site_area_sqm", "far"],
      "properties": {
        "site_area_sqm":    { "type": "number", "description": "基地面積（使照面積，m²）" },
        "plaza_area_sqm":   { "type": "number", "description": "人行廣場退縮（m²）" },
        "far":              { "type": "number", "description": "法定容積率" },
        "bonus_ratio":      { "type": "number", "description": "容積獎勵率合計（各項自動加總）" },
        "bonus_breakdown":  { "type": "object", "description": "獎勵拆解明細 {項目key: 比率}" },
        "tdr_transfer_sqm": { "type": "number", "description": "容積移轉（m²）" }
      }
    },
    "building": {
      "type": "object",
      "properties": {
        "public_ratio":          { "type": "number", "description": "公設比" },
        "stair_hall_exempt_pct": { "type": "number", "description": "梯廳免計基準（5 或 8）" },
        "balcony_exempt_pct":    { "type": "number", "description": "陽台免計基準（10 或 15）" },
        "unit_count":            { "type": "integer", "description": "戶數" }
      }
    },
    "owners": {
      "type": "array",
      "description": "地主清冊（權利事實欄位；規格由 Urban-Renewal 消費端提出，2026-07 對齊）。空陣列＝總量可信、逐戶不可算，消費端已約定此語意。",
      "items": {
        "type": "object",
        "required": ["owner_id", "land_share", "pre_building_area_sqm", "pre_value", "consent"],
        "properties": {
          "owner_id":              { "type": "string", "description": "匿名代號（如 W01），不放真實姓名" },
          "land_share":            { "type": "number", "minimum": 0, "maximum": 1, "description": "土地持分（0–1）；分回與同意門檻計算的根" },
          "pre_building_area_sqm": { "type": "number", "minimum": 0, "description": "更新前建物面積（0＝純空地持分）" },
          "pre_value":             { "type": "number", "description": "更新前權利價值（萬元）；Σ 應 ≈ result.pre_renewal_value" },
          "consent":               { "type": "string", "enum": ["agreed", "pending", "opposed"], "description": "同意狀態" },
          "min_unit_eligible":     { "type": "boolean", "description": "是否達最小分配單元；未達則領補償金" },
          "return_value":          { "type": "number", "description": "逐戶分回價值（萬元，回算後填入）" },
          "equalization":          { "type": "number", "description": "找補金（萬元，正=補入/負=找出，回算後填入）" },
          "selected_units":        { "type": "array", "description": "選配戶別（Phase 2 選屋用）", "items": { "type": "string" } }
        }
      }
    },
    "finance": {
      "type": "object",
      "properties": {
        "residential_price":  { "type": "number", "description": "住宅單價（萬/坪）" },
        "shop_area":          { "type": "number", "description": "店舖坪數" },
        "shop_price":         { "type": "number", "description": "店舖單價（萬/坪）" },
        "parking_count":      { "type": "integer", "description": "車位數" },
        "parking_price":      { "type": "number", "description": "車位單價（萬/位）" },
        "construction_price": { "type": "number", "description": "營造單價（萬/坪）" }
      }
    },
    "result": {
      "type": "object",
      "description": "RE-DCF Core 計算結果（唯一可信數值來源，含健檢判斷）",
      "required": [
        "baseline_far", "allow_floor_area", "used_floor_area",
        "remaining_floor_area", "saleable_area", "efficiency_ratio",
        "warnings", "computed_at", "core_version"
      ],
      "properties": {
        "baseline_far":         { "type": "number", "description": "基準容積 FA（m²）" },
        "allow_floor_area":     { "type": "number", "description": "允建容積（m²）" },
        "used_floor_area":      { "type": "number", "description": "計入容積_修正後（m²）" },
        "remaining_floor_area": { "type": "number", "description": "容積餘量（m²，負值=超出）" },
        "stair_exempt_cap":     { "type": "number", "description": "安全梯免計上限（允建×15%）" },
        "balcony_exempt_area":  { "type": "number", "description": "陽台免計面積（m²）" },
        "saleable_area":        { "type": "number", "description": "銷售坪數" },
        "efficiency_ratio":     { "type": "number", "description": "銷坪比（正常 1.58–1.68）" },
        "total_sales":          { "type": "number", "description": "總銷（萬元）" },
        "shared_cost":          { "type": "number", "description": "共同負擔合計（萬元）" },
        "shared_cost_ratio":    { "type": "number", "description": "共負比" },
        "owner_return_value":   { "type": "number", "description": "地主分回價值（萬元）" },
        "owner_return_ratio":   { "type": "number", "description": "地主分回比" },
        "return_rate":          { "type": "number", "description": "報酬率（利潤/總成本）" },
        "pre_renewal_value":    { "type": "number", "description": "更新前總值（萬元，L7）" },
        "value_multiple":       { "type": "number", "description": "增值倍率（地主分回 / 更新前總值）" },
        "warnings": {
          "type": "array",
          "description": "Core 統一健檢判斷；消費端只讀不重判門檻，避免兩端邏輯分歧",
          "items": {
            "type": "object",
            "required": ["code", "level", "message"],
            "properties": {
              "code":    { "type": "string", "description": "如 EFFICIENCY_OUT_OF_BAND / VOLUME_EXCEEDED / SHARED_COST_HIGH / SHARED_COST_LOW / VALUE_MULTIPLE_LOW / OWNERS_SHARE_MISMATCH / OWNERS_VALUE_MISMATCH" },
              "level":   { "type": "string", "enum": ["info", "warn", "error"], "description": "info=提示 / warn=黃燈 / error=紅燈" },
              "message": { "type": "string", "description": "人類可讀說明（中文）" },
              "field":   { "type": "string", "description": "對應的 result 欄位名（可選）" }
            }
          }
        },
        "computed_at":  { "type": "string", "format": "date-time", "description": "本結果計算時間（ISO 8601, UTC）" },
        "core_version": { "type": "string", "description": "計算此結果的 Core Engine 版本（core/_version.py）" }
      }
    }
  }
}
